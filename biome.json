{
  "$schema": "https://biomejs.dev/schemas/1.8.0/schema.json",

  "vcs": {
    "enabled": true,

    "clientKind": "git",

    "useIgnoreFile": true
  },

  "organizeImports": {
    "enabled": true
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "include": ["app/**"],
    "lineEnding": "crlf",
    "indentWidth": 2,

    "lineWidth": 100
  },

  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },

    "formatter": {
      "enabled": true,

      "quoteStyle": "single",

      "jsxQuoteStyle": "single",

      "trailingCommas": "all",

      "semicolons": "always",

      "arrowParentheses": "always",

      "quoteProperties": "asNeeded",
      "lineEnding": "crlf",
      "attributePosition": "multiline"
    }
  },

  "css": {
    "formatter": {
      "enabled": true,

      "indentWidth": 2,

      "indentStyle": "space"
    }
  },

  "linter": {
    "enabled": true,

    "ignore": ["**/*.css"],

    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noConfusingVoidType": "off"
      },
      "style": {
        "noUselessElse": "off",
        "noNonNullAssertion": "off",
        "useSelfClosingElements": "off"
      },
      "complexity": {
        "noForEach": "off"
      }
    }
  }
}
